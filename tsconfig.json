{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "hooks/**/*",
    "services/**/*",
    "types/**/*",
    "constants/**/*"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "app.config.ts"
  ]
}